  "version": "0.2.0",
  "configurations": [
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "Dev",
      "skipFiles": ["<node_internals>/**"],
      "command": "pnpm run dev",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/**/*.js"],
      "internalConsoleOptions": "openOnSessionStart"
    },
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "Test",
      "skipFiles": ["<node_internals>/**"],
      "command": "pnpm run test",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/**/*.js"],
      "internalConsoleOptions": "openOnSessionStart"
    }
  ]
}
